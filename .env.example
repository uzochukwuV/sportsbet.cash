# ─── Deployment ──────────────────────────────────────────────────────────────
# WIF-encoded private key for the deployer wallet (KEEP SECRET)
DEPLOY_WIF=your_wif_private_key_here

# Network: chipnet (testnet) or mainnet
NETWORK=chipnet

# Initial liquidity per side in satoshis (default: 10 BCH = 1_000_000_000)
INITIAL_LIQUIDITY=1000000000

# Blocks until halftime reveal (BCH ≈ 10 min/block; 6 ≈ 1 hour)
HALFTIME_OFFSET=6

# Blocks until final reveal (12 ≈ 2 hours)
FINAL_OFFSET=12
